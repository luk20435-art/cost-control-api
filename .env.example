PORT=3001
FRONTEND_ORIGIN=http://localhost:3000

JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=1d

ADMIN_USERNAME=admin
ADMIN_PASSWORD=123
# Optional alternative to ADMIN_PASSWORD: a bcrypt hash takes precedence if set.
# Generate with: node -e "console.log(require('bcrypt').hashSync('yourpassword', 10))"
# ADMIN_PASSWORD_HASH=

COOKIE_SECURE=false
